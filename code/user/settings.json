    "editor.tokenColorCustomizations": {
        "[E Ink 陰陽 Light]": {
            "textMateRules": [
                {
                    "scope": "variable.other",
                    "settings": {
                        "foreground": "#ae749a"
                    }
                },
                {
                    "scope": "variable.other.property",
                    "settings": {
                        "foreground": "#e7798b"
                    }
                },
                {
                    "scope": "variable.other.enummember",
                    "settings": {
                        "foreground": "#ae749a"
                    }
                },
                {
                    "scope": "variable.language",
                    "settings": {
                        "foreground": "#a0a329"
                    }
                },
                {
                    "scope": "entity.name.function",
                    "settings": {
                        "foreground": "#c37722"
                    }
                },
                {
                    "scope": "string.quoted.single, string.quoted.double, string.unquoted, string.regexp",
                    "settings": {
                        "foreground": "#474747"
                    }
                },
                {
                    "scope": "comment, comment.line, comment.line.number-sign, comment.block",
                    "settings": {
                        "foreground": "#7a7a7a"
                    }
                },
                {
                    "scope": "constant.numeric, constant.other",
                    "settings": {
                        "foreground": "#5a5a5a"
                    }
                },
                {
                    "scope": "invalid, invalid.deprecated, invalid.illegal",
                    "settings": {
                        "foreground": "#ec4e4e"
                    }
                },
            ]
        },
        "[E Ink 陰陽 Dark]": {
            "textMateRules": [
                {
                    "scope": "variable.other",
                    "settings": {
                        "foreground": "#b994a8"
                    }
                },
                {
                    "scope": "variable.other.property",
                    "settings": {
                        "foreground": "#e7798b"
                    }
                },
                {
                    "scope": "variable.other.enummember",
                    "settings": {
                        "foreground": "#ae749a"
                    }
                },
                {
                    "scope": "variable.language",
                    "settings": {
                        "foreground": "#a0a329"
                    }
                },
                {
                    "scope": "entity.name.function",
                    "settings": {
                        "foreground": "#c37722"
                    }
                },
                {
                    "scope": "string.quoted.single, string.quoted.double, string.unquoted, string.regexp",
                    "settings": {
                        "foreground": "#f5dbead4"
                    }
                },
                {
                    "scope": "comment, comment.line, comment.line.number-sign, comment.block",
                    "settings": {
                        "foreground": "#cccccc"
                    }
                },
                {
                    "scope": "constant.numeric, constant.other",
                    "settings": {
                        "foreground": "#f5dbea"
                    }
                },
                {
                    "scope": "invalid, invalid.deprecated, invalid.illegal",
                    "settings": {
                        "foreground": "#ec4e4e"
                    }
                },
                {
                    "scope": "keyword.control",
                    "settings": {
                        "foreground": "#f5dbeaa4"
                    }
                },
            ]
        }
    },
    "editor.semanticTokenColorCustomizations": {
